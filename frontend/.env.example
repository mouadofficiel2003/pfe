# Copier vers .env.development.local (recommandé) ou .env.development, puis adapter.

# Origine du auth-service — cible du proxy Vite pour les chemins /auth/*
VITE_AUTH_SERVICE_ORIGIN=http://localhost:8081

# Origine du candidat-service — cible du proxy Vite pour les chemins /api/candidats*
VITE_CANDIDAT_SERVICE_ORIGIN=http://localhost:8082

# Origine du concours-service — cible du proxy Vite pour les chemins /api/concours*
VITE_CONCOURS_SERVICE_ORIGIN=http://localhost:8083

# Origine du lieux-service — cible du proxy Vite pour /api/centres*, /api/etablissements*, /api/salles*
VITE_LIEUX_SERVICE_ORIGIN=http://localhost:8084

# Base URL des appels HTTP candidats depuis le navigateur (Axios).
# Laisser vide en développement : requêtes relatives → proxy Vite ci-dessus.
# Renseigner en prod si le front est servi sur un autre domaine que l’API (ex. https://api.example.com).
# VITE_CANDIDAT_API_BASE_URL=
